{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "elisptred",
      "camelcase": "ElispTred",
      "title": "ElispTred",
      "scope": "source.elisptred",
      "file-types": [
        ".el"
      ],
      "injection-regex": "^elisptred$",
      "class-name": "TreeSitterElisptred"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Elisptred grammar for tree-sitter",
    "authors": [
      {
        "name": "Ben Vandervalk",
        "email": "ben.vvalk@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-elisptred"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}